generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CommunityPostCategory {
  GENERAL
  QUESTION
  EVENT
  FOR_SALE
  SAFETY
  FREE
}

enum CommunityPostStatus {
  ACTIVE
  HIDDEN
  DELETED
}

enum CommunityItemCondition {
  BRAND_NEW
  LIKE_NEW
  GOOD
  FAIR
  FOR_PARTS
}

model CommunityPost {
  id BigInt @id @default(autoincrement()) @map("cp_id")

  // user/customer id ng nag-post
  authorId BigInt   @map("cp_author_id")
  author   Customer @relation(fields: [authorId], references: [id])

  category CommunityPostCategory @map("cp_category")
  title    String                @map("cp_title")
  content  String                @map("cp_content") @db.Text

  imageUrl String? @map("cp_image_url")

  // for event posts
  eventDate    DateTime? @map("cp_event_date")
  eventTime    String?   @map("cp_event_time")
  eventEndTime String?   @map("cp_event_end_time")

  // for event/safety posts
  location  String?  @map("cp_location")
  latitude  Decimal? @map("cp_latitude") @db.Decimal(10, 7)
  longitude Decimal? @map("cp_longitude") @db.Decimal(10, 7)

  // for sale posts 
  price     Decimal?                @map("cp_price") @db.Decimal(10, 2)
  condition CommunityItemCondition? @map("cp_condition")

  status CommunityPostStatus @default(ACTIVE) @map("cp_status")

  // repost — points to the original post being reshared (quote repost)
  repostOfId BigInt?        @map("cp_repost_of_id")
  repostOf   CommunityPost? @relation("Reposts", fields: [repostOfId], references: [id])
  reposts    CommunityPost[] @relation("Reposts")

  createdAt DateTime @default(now()) @map("cp_created_at")
  updatedAt DateTime @updatedAt @map("cp_updated_at")

  comments  CommunityComment[]
  reactions CommunityReaction[]
  rsvps     CommunityEventRsvp[]
  savedBy   CommunitySavedPost[]

  @@index([authorId])
  @@index([category])
  @@index([createdAt])
  @@map("tbl_community_posts")
}

model CommunityComment {
  id BigInt @id @default(autoincrement()) @map("cc_id")

  postId   BigInt  @map("cc_post_id")
  authorId BigInt  @map("cc_author_id")
  parentId BigInt? @map("cc_parent_id")

  content String @map("cc_content") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  post    CommunityPost     @relation(fields: [postId], references: [id], onDelete: Cascade)
  author  Customer          @relation(fields: [authorId], references: [id])
  parent  CommunityComment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies CommunityComment[] @relation("CommentReplies")

  @@index([postId])
  @@index([authorId])
  @@index([parentId])
  @@map("tbl_community_comments")
}

model CommunityReaction {
  id BigInt @id @default(autoincrement()) @map("cr_id")

  postId   BigInt @map("cr_post_id")
  authorId BigInt @map("cr_author_id")

  type String @default("LIKE") @map("cr_type")

  createdAt DateTime @default(now()) @map("created_at")

  post   CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  author Customer      @relation(fields: [authorId], references: [id])

  @@unique([postId, authorId])
  @@index([postId])
  @@index([authorId])
  @@map("tbl_community_reactions")
}

enum EventRsvpStatus {
  GOING
  INTERESTED
}

model CommunityEventRsvp {
  id BigInt @id @default(autoincrement()) @map("re_id")

  postId BigInt @map("re_post_id")
  userId BigInt @map("re_user_id")

  status EventRsvpStatus @map("re_status")

  createdAt DateTime @default(now()) @map("re_created_at")
  updatedAt DateTime @updatedAt @map("re_updated_at")

  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user Customer      @relation(fields: [userId], references: [id])

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
  @@map("tbl_community_event_rsvps")
}

enum CommunityNotificationType {
  NEW_POST
  NEW_COMMENT
  NEW_REPLY
  NEW_REACTION
  NEW_RSVP
  NEW_REPOST
  CONNECT_REQUEST
  CONNECT_ACCEPTED
}

model CommunityNotification {
  id BigInt @id @default(autoincrement()) @map("cn_id")

  // recipient — kung sino ang dapat makakita ng notif
  userId BigInt   @map("cn_user_id")
  user   Customer @relation(fields: [userId], references: [id], onDelete: Cascade)

  type    CommunityNotificationType @map("cn_type")
  payload Json                      @map("cn_payload")

  read   Boolean @default(false) @map("cn_read")

  createdAt DateTime @default(now()) @map("cn_created_at")

  @@index([userId])
  @@index([userId, read])
  @@index([createdAt])
  @@map("tbl_community_notifications")
}

model Conversation {
  id BigInt @id @default(autoincrement()) @map("conv_id")

  createdAt DateTime @default(now()) @map("conv_created_at")
  updatedAt DateTime @updatedAt @map("conv_updated_at") // bumps on new message (for sorting)

  participants ConversationParticipant[]
  messages     Message[]

  @@map("tbl_community_conversations")
}

model ConversationParticipant {
  conversationId BigInt    @map("ccp_conversation_id")
  userId         BigInt    @map("ccp_user_id")
  lastReadAt     DateTime? @map("ccp_last_read_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         Customer     @relation(fields: [userId], references: [id])

  @@id([conversationId, userId])
  @@index([userId])
  @@map("tbl_community_conversation_participants")
}

model Message {
  id BigInt @id @default(autoincrement()) @map("msg_id")

  conversationId BigInt  @map("msg_conversation_id")
  senderId       BigInt  @map("msg_sender_id")
  content        String  @map("msg_content") @db.Text
  imageUrl       String? @map("msg_image_url")

  createdAt DateTime @default(now()) @map("msg_created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       Customer     @relation(fields: [senderId], references: [id])

  @@index([conversationId])
  @@index([senderId])
  @@map("tbl_community_messages")
}

model CommunitySavedPost {
  id BigInt @id @default(autoincrement()) @map("csp_id")

  userId BigInt @map("csp_user_id")
  postId BigInt @map("csp_post_id")

  createdAt DateTime @default(now()) @map("csp_created_at")

  user Customer      @relation(fields: [userId], references: [id])
  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([userId])
  @@map("tbl_community_saved_posts")
}

model Customer {
  id        BigInt  @id @map("c_userid")
  firstName String? @map("c_fname")
  lastName  String? @map("c_lname")
  email     String? @map("c_email")
  avatarUrl String? @map("c_avatar_url")

  posts         CommunityPost[]
  comments      CommunityComment[]
  reactions     CommunityReaction[]
  notifications CommunityNotification[]
  rsvps         CommunityEventRsvp[]
  conversations ConversationParticipant[]
  messages      Message[]
  savedPosts    CommunitySavedPost[]
  profile       CommunityProfile?
  connectionsRequested CommunityConnection[] @relation("ConnectionsRequested")
  connectionsReceived  CommunityConnection[] @relation("ConnectionsReceived")

  @@map("tbl_customer")
}

enum CommunityConnectionStatus {
  PENDING
  ACCEPTED
}

model CommunityConnection {
  id          BigInt   @id @default(autoincrement()) @map("cc_id")
  requesterId BigInt   @map("cc_requester_id")
  addresseeId BigInt   @map("cc_addressee_id")
  requester   Customer @relation("ConnectionsRequested", fields: [requesterId], references: [id])
  addressee   Customer @relation("ConnectionsReceived", fields: [addresseeId], references: [id])

  status CommunityConnectionStatus @default(PENDING) @map("cc_status")

  createdAt DateTime @default(now()) @map("cc_created_at")
  updatedAt DateTime @updatedAt @map("cc_updated_at")

  @@unique([requesterId, addresseeId])
  @@index([addresseeId])
  @@map("tbl_community_connections")
}

model CommunityProfile {
  id         BigInt   @id @default(autoincrement()) @map("cprof_id")
  customerId BigInt   @unique @map("cprof_customer_id")
  customer   Customer @relation(fields: [customerId], references: [id])

  bio        String?  @map("cprof_bio") @db.Text
  location   String?  @map("cprof_location")
  coverUrl   String?  @map("cprof_cover_url")
  occupation String?  @map("cprof_occupation")
  role       String?  @map("cprof_role")
  interests  String[] @map("cprof_interests")

  createdAt DateTime @default(now()) @map("cprof_created_at")
  updatedAt DateTime @updatedAt @map("cprof_updated_at")

  @@map("tbl_community_profiles")
}

model PersonalAccessToken {
  id            BigInt    @id @default(autoincrement())
  tokenableType String    @map("tokenable_type")
  tokenableId   BigInt    @map("tokenable_id")
  name          String
  token         String    @unique
  abilities     String?
  lastUsedAt    DateTime? @map("last_used_at")
  expiresAt     DateTime? @map("expires_at")
  createdAt     DateTime? @map("created_at")
  updatedAt     DateTime? @map("updated_at")

  @@index([tokenableType, tokenableId])
  @@map("personal_access_tokens")
}
