{
  "name": "fullstack-apsara",
  "private": true,
  "packageManager": "pnpm@11.3.0",
  "scripts": {
    "dev:frontend": "pnpm --filter apsara-home-frontend dev",
    "dev:backend": "pnpm --filter apsara-home-backend dev",
    "dev:backend:local": "pnpm --filter apsara-home-backend dev:local",
    "dev:community-frontend": "pnpm --filter community-frontend dev",
    "dev:community-backend": "pnpm --filter community-backend dev",
    "dev:realtime": "pnpm --filter realtime-service dev",
    "dev:redis": "docker compose up -d redis",
    "dev:community": "pnpm --filter community-frontend --filter community-backend --filter realtime-service --parallel dev",
    "dev:dreambuild": "pnpm --filter dreambuild dev",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint"
  }
}
