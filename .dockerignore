# ── VCS / CI ──────────────────────────────────────────────────────────
.git
.github
.gitignore

# ── Dependencies (reinstalled inside the image) ───────────────────────
node_modules
**/node_modules
**/node_modules/
apps/Apsara-Home-Mobile
apps/Apsara-Home-Mobile/**
.pnpm-store
**/vendor

# ── Build output (regenerated inside the image) ───────────────────────
**/.next
**/.next_build
**/dist
**/build
**/out
**/.turbo
**/coverage

# ── Env / secrets (injected at runtime, never baked) ──────────────────
**/.env
**/.env.*
!**/.env.example
!**/.env.docker.example

# ── Logs / caches ─────────────────────────────────────────────────────
**/storage/logs
*.log
.codex-frontend*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.psysh

# ── Lockfiles from other package managers ─────────────────────────────
package-lock.json
**/package-lock.json

# ── Docs / context / editor cruft (not needed in images) ──────────────
6_file_context
**/*.md.txt
.vscode
.idea
.DS_Store
Thumbs.db

# Hard excludes last: later negation rules can otherwise make BuildKit walk these.
node_modules
**/node_modules
**/node_modules/
apps/Apsara-Home-Mobile
apps/Apsara-Home-Mobile/**
